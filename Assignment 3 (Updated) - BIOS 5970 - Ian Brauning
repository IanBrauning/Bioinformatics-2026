sed '/[Zz]oo/d' pandas.tsv > panda_zoos.txt
awk -F'\t' '{print $1, $2, $3}' pandas.tsv | sort -k3 > sorted_pandas.txt
grep -o '[A-Za-z_]*' pandas.tsv | grep '_' | sort -u > panda_zoos_A2Z.txt
sed 's/female/F/g; s/male/M/g' pandas.tsv > panda_m_f.txt
grep -c 'female.*October' pandas.tsv
grep -n '' pandas.tsv > panda_names.txt
sed -n '1p;6p;17p' pandas.tsv > lines_1_6_17.txt
grep '[Xx]' pandas.tsv > x_lines.txt
awk '{print $5}' pandas.tsv | sort | uniq -u > unique_places.txt
awk '{if ($4 <= 10) print $1, $4}' pandas.tsv | sort -k2 -n > young_pandas.txt